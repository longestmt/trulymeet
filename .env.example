# ═══════════════════════════════════════════════════════════
# TrulyMeet — Environment Variables
# Copy this file to .env and edit as needed.
# ═══════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection URL
DATABASE_URL=postgres://trulymeet:trulymeet@localhost:5432/trulymeet

# ── Application ───────────────────────────────────────────
# Public-facing base URL (used for generating event links)
BASE_URL=http://localhost:5173

# Event retention: events are deleted after this many days of inactivity
EVENT_RETENTION_DAYS=30

# ── Rate Limiting ─────────────────────────────────────────
# Maximum event creations per IP per hour
RATE_LIMIT_EVENTS_PER_HOUR=10

# Maximum availability submissions per event per hour
RATE_LIMIT_SUBMISSIONS_PER_HOUR=60

# ── Optional ──────────────────────────────────────────────
# Custom accent color override (CSS color value)
# ACCENT_COLOR=#b4bcc4
